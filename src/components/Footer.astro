</footer>

<style>
    .footer {
        background: var(--color-dark-800);
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding: 4rem 0 0;
    }

    .footer__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
        padding-bottom: 3rem;
    }

    .footer__brand-desc {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        line-height: 1.7;
        margin-top: 1rem;
        max-width: 320px;
    }

    .footer__title {
        font-family: var(--font-heading);
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--color-white);
        margin-bottom: 1.25rem;
    }

    .footer__links {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .footer__link {
        font-size: 0.88rem;
        color: var(--color-text-muted);
        transition: color var(--transition-fast);
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

    .footer__link:hover {
        color: var(--color-primary);
    }

    .footer__link i {
        width: 14px;
        height: 14px;
    }

    .footer__socials {
        display: flex;
        gap: 0.75rem;
    }

    .footer__social {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-dark-700);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: var(--radius-sm);
        color: var(--color-text-muted);
        transition: all var(--transition-fast);
    }

    .footer__social:hover {
        background: var(--color-primary);
        border-color: var(--color-primary);
        color: var(--color-dark);
        transform: translateY(-2px);
    }

    .footer__social i {
        width: 18px;
        height: 18px;
    }

    .footer__bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding: 1.5rem 0;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    .footer__copyright {
        font-size: 0.82rem;
        color: var(--color-text-muted);
    }

    .footer__bottom-links {
        display: flex;
        gap: 1.5rem;
    }

    .footer__bottom-link {
        font-size: 0.82rem;
        color: var(--color-text-muted);
    }

    .footer__bottom-link:hover {
        color: var(--color-primary);
    }
</style>
