---
// Footer component — Pie de página con columnas
---

<footer class="footer" id="footer">
    <div class="container">
        <div class="footer__grid">
            <div>
                <a
                    href="#hero"
                    class="navbar__logo"
                    aria-label="JorgeCorp - Inicio"
                >
                    <div class="navbar__logo-icon">
                        <i data-lucide="building-2"></i>
                    </div>
                    JorgeCorp
                </a>
                <p class="footer__brand-desc">
                    Construimos con calidad, seguridad y compromiso ambiental.
                    Su proyecto en manos de expertos.
                </p>
            </div>

            <div>
                <h3 class="footer__title">Proyectos</h3>
                <ul class="footer__links">
                    <li>
                        <a href="#projects" class="footer__link"
                            >Proyectos residenciales</a
                        >
                    </li>
                    <li>
                        <a href="#projects" class="footer__link"
                            >Proyectos comerciales</a
                        >
                    </li>
                    <li>
                        <a href="#projects" class="footer__link"
                            >Proyectos industriales</a
                        >
                    </li>
                    <li>
                        <a href="#projects" class="footer__link"
                            >Infraestructura</a
                        >
                    </li>
                </ul>
            </div>

            <div>
                <h3 class="footer__title">Compromisos</h3>
                <ul class="footer__links">
                    <li>
                        <a href="#about" class="footer__link"
                            >Compromisos ambientales</a
                        >
                    </li>
                    <li>
                        <a href="#about" class="footer__link"
                            >Calidad certificada</a
                        >
                    </li>
                    <li>
                        <a href="#about" class="footer__link"
                            >Seguridad laboral</a
                        >
                    </li>
                    <li>
                        <a href="#about" class="footer__link"
                            >Responsabilidad social</a
                        >
                    </li>
                </ul>
            </div>

            <div>
                <h3 class="footer__title">Seguinos</h3>
                <div class="footer__socials">
                    <a href="#" class="footer__social" aria-label="Facebook">
                        <i data-lucide="facebook"></i>
                    </a>
                    <a href="#" class="footer__social" aria-label="Instagram">
                        <i data-lucide="instagram"></i>
                    </a>
                    <a href="#" class="footer__social" aria-label="LinkedIn">
                        <i data-lucide="linkedin"></i>
                    </a>
                    <a href="#" class="footer__social" aria-label="YouTube">
                        <i data-lucide="youtube"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="footer__bottom">
            <p class="footer__copyright">
                &copy; <span id="currentYear"></span> NicoS92. Todos los derechos
                reservados.
            </p>
            <div class="footer__bottom-links">
                <a href="#" class="footer__bottom-link"
                    >Política de privacidad</a
                >
                <a href="#" class="footer__bottom-link">Términos de uso</a>
            </div>
        </div>
    </div>
</footer>

<style>
    .footer {
        background: var(--color-dark-800);
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding: 4rem 0 0;
    }

    .footer__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
        padding-bottom: 3rem;
    }

    .footer__brand-desc {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        line-height: 1.7;
        margin-top: 1rem;
        max-width: 320px;
    }

    .footer__title {
        font-family: var(--font-heading);
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--color-white);
        margin-bottom: 1.25rem;
    }

    .footer__links {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .footer__link {
        font-size: 0.88rem;
        color: var(--color-text-muted);
        transition: color var(--transition-fast);
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

    .footer__link:hover {
        color: var(--color-primary);
    }

    .footer__link i {
        width: 14px;
        height: 14px;
    }

    .footer__socials {
        display: flex;
        gap: 0.75rem;
    }

    .footer__social {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-dark-700);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: var(--radius-sm);
        color: var(--color-text-muted);
        transition: all var(--transition-fast);
    }

    .footer__social:hover {
        background: var(--color-primary);
        border-color: var(--color-primary);
        color: var(--color-dark);
        transform: translateY(-2px);
    }

    .footer__social i {
        width: 18px;
        height: 18px;
    }

    .footer__bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding: 1.5rem 0;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    .footer__copyright {
        font-size: 0.82rem;
        color: var(--color-text-muted);
    }

    .footer__bottom-links {
        display: flex;
        gap: 1.5rem;
    }

    .footer__bottom-link {
        font-size: 0.82rem;
        color: var(--color-text-muted);
    }

    .footer__bottom-link:hover {
        color: var(--color-primary);
    }
</style>
