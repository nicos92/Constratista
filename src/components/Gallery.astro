---
// Gallery section — Cuadrícula de imágenes con lightbox
---

<section class="gallery" id="gallery">
    <div class="container">
        <div class="gallery__header">
            <span class="section-label reveal">Nuestro trabajo</span>
            <h2 class="section-title reveal reveal-delay-1">
                Galería de obras
            </h2>
            <p class="section-subtitle reveal reveal-delay-2">
                Imágenes que reflejan nuestra trayectoria y compromiso con la
                excelencia constructiva.
            </p>
        </div>

        <div class="gallery__grid">
            <div
                class="gallery__item reveal reveal-delay-1"
                role="button"
                tabindex="0"
                aria-label="Ver imagen de galería: Cimentación profunda"
            >
                <img
                    src="https://images.unsplash.com/photo-1590644365607-1c5e64067c41?q=80&w=600&auto=format&fit=crop"
                    alt="Cimentación profunda en obra comercial"
                    loading="lazy"
                />
                <div class="gallery__item-overlay">
                    <i data-lucide="maximize-2"></i>
                </div>
            </div>
            <div
                class="gallery__item reveal reveal-delay-2"
                role="button"
                tabindex="0"
                aria-label="Ver imagen de galería: Estructura metálica"
            >
                <img
                    src="https://images.unsplash.com/photo-1581094794329-c8112a89af12?q=80&w=600&auto=format&fit=crop"
                    alt="Estructura metálica de nave industrial"
                    loading="lazy"
                />
                <div class="gallery__item-overlay">
                    <i data-lucide="maximize-2"></i>
                </div>
            </div>
            <div
                class="gallery__item reveal reveal-delay-3"
                role="button"
                tabindex="0"
                aria-label="Ver imagen de galería: Acabados interiores"
            >
                <img
                    src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=600&auto=format&fit=crop"
                    alt="Acabados interiores de proyecto residencial"
                    loading="lazy"
                />
                <div class="gallery__item-overlay">
                    <i data-lucide="maximize-2"></i>
                </div>
            </div>
            <div
                class="gallery__item reveal reveal-delay-4"
                role="button"
                tabindex="0"
                aria-label="Ver imagen de galería: Equipos en obra"
            >
                <img
                    src="https://images.unsplash.com/photo-1589939705384-5185137a7f0f?q=80&w=600&auto=format&fit=crop"
                    alt="Equipos de construcción en obra"
                    loading="lazy"
                />
                <div class="gallery__item-overlay">
                    <i data-lucide="maximize-2"></i>
                </div>
            </div>
            <div
                class="gallery__item reveal reveal-delay-1"
                role="button"
                tabindex="0"
                aria-label="Ver imagen de galería: Vista aérea del proyecto"
            >
                <img
                    src="https://images.unsplash.com/photo-1487958449943-2429e8be8625?q=80&w=600&auto=format&fit=crop"
                    alt="Vista aérea de proyecto comercial terminado"
                    loading="lazy"
                />
                <div class="gallery__item-overlay">
                    <i data-lucide="maximize-2"></i>
                </div>
            </div>
            <div
                class="gallery__item reveal reveal-delay-2"
                role="button"
                tabindex="0"
                aria-label="Ver imagen de galería: Detalles arquitectónicos"
            >
                <img
                    src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?q=80&w=600&auto=format&fit=crop"
                    alt="Detalles arquitectónicos modernos"
                    loading="lazy"
                />
                <div class="gallery__item-overlay">
                    <i data-lucide="maximize-2"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .gallery {
        padding: var(--section-padding) 0;
        background: var(--color-dark);
    }

    .gallery__header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .gallery__header .section-subtitle {
        margin: 0 auto;
    }

    .gallery__grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
        gap: 1rem;
    }

    .gallery__item {
        position: relative;
        border-radius: var(--radius-md);
        overflow: hidden;
        aspect-ratio: 4 / 3;
        cursor: pointer;
    }

    .gallery__item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform var(--transition-slow);
    }

    .gallery__item:hover img {
        transform: scale(1.1);
    }

    .gallery__item-overlay {
        position: absolute;
        inset: 0;
        background: rgba(15, 17, 21, 0);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background var(--transition-base);
    }

    .gallery__item:hover .gallery__item-overlay {
        background: rgba(15, 17, 21, 0.5);
    }

    .gallery__item-overlay i {
        width: 32px;
        height: 32px;
        color: var(--color-white);
        opacity: 0;
        transform: scale(0.8);
        transition: all var(--transition-base);
    }

    .gallery__item:hover .gallery__item-overlay i {
        opacity: 1;
        transform: scale(1);
    }
</style>
